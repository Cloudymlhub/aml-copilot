# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=aml_compliance
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0                # Deprecated - use REDIS_DB_CACHE or REDIS_DB_CHECKPOINTS
REDIS_DB_CACHE=0         # For data caching
REDIS_DB_CHECKPOINTS=1   # For LangGraph state persistence
# REDIS_PASSWORD=

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# LLM Configuration (Deprecated - use per-agent settings below)
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.1

# Coordinator Agent Configuration (routing decisions)
COORDINATOR_MODEL=gpt-4o-mini
COORDINATOR_TEMPERATURE=0.0
COORDINATOR_MAX_RETRIES=3
COORDINATOR_TIMEOUT=60

# Intent Mapper Agent Configuration (query understanding)
INTENT_MAPPER_MODEL=gpt-4o-mini
INTENT_MAPPER_TEMPERATURE=0.0
INTENT_MAPPER_MAX_RETRIES=3
INTENT_MAPPER_TIMEOUT=60

# Data Retrieval Agent Configuration (tool execution)
DATA_RETRIEVAL_MODEL=gpt-4o-mini
DATA_RETRIEVAL_TEMPERATURE=0.0
DATA_RETRIEVAL_MAX_RETRIES=3
DATA_RETRIEVAL_TIMEOUT=60

# Compliance Expert Agent Configuration (analysis & recommendations)
COMPLIANCE_EXPERT_MODEL=gpt-4o         # More powerful model for compliance
COMPLIANCE_EXPERT_TEMPERATURE=0.1
COMPLIANCE_EXPERT_MAX_RETRIES=3
COMPLIANCE_EXPERT_TIMEOUT=120          # More time for complex analysis

# Agent Configuration
MAX_AGENT_ITERATIONS=10
AGENT_TIMEOUT=300

# Cache Configuration
CACHE_TTL=3600
ENABLE_CACHING=true

# Logging
LOG_LEVEL=INFO
