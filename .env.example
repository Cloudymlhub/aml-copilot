# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=aml_compliance
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.1

# Agent Configuration
MAX_AGENT_ITERATIONS=10
AGENT_TIMEOUT=300

# Cache Configuration
CACHE_TTL=3600
ENABLE_CACHING=true

# Logging
LOG_LEVEL=INFO
