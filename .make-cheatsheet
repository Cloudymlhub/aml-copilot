🚀 QUICK START
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  make setup          # First-time setup (install + services + DB)
  make start          # Start services and API
  make stop           # Stop everything
  make status         # Check system status
  make help           # Show all available commands

📦 API COMMANDS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  make api-run        # Run API (dev mode with auto-reload)
  make api-dev        # Start services + run API
  make api-prod       # Run API (production mode)

  → API: http://localhost:8000
  → Docs: http://localhost:8000/docs

🗄️  DATABASE COMMANDS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  make db-start       # Start PostgreSQL
  make db-migrate     # Run migrations
  make db-seed        # Load mock data
  make db-refresh     # ⚠️  Full refresh (reset + migrate + seed)
  make db-shell       # Open PostgreSQL shell
  make db-backup      # Backup database
  make db-status      # Check DB connection

🔴 REDIS COMMANDS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
