⚡ COMMON WORKFLOWS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  Start of day:
    make status && make api-run

  Fresh database:
    make db-refresh

  Complete reset:
    make services-clean && make setup

  Debug database:
    make db-shell
    # SELECT * FROM customers LIMIT 5;

  Debug cache:
    make redis-cli
    # KEYS *

  Test API interactively:
    Terminal 1: make api-run
    Terminal 2: make notebook
    Open: notebooks/api_testing.ipynb

