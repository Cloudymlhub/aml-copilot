  make redis-cli      # Open Redis CLI
  make redis-flush    # ⚠️  Clear all cache
  make redis-info     # Show Redis stats
  make redis-status   # Check Redis connection

🐳 DOCKER SERVICES
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  make services-start    # Start all services (PostgreSQL + Redis)
  make services-stop     # Stop all services
  make services-restart  # Restart services
  make services-status   # Check service status
  make services-logs     # View live logs
  make services-clean    # ⚠️  Remove all volumes (deletes data)

🧪 DEVELOPMENT & TESTING
